{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.leilashellroot/confluence-data-center-mcp",
  "description": "MCP server for Confluence Server/Data Center with complete document and comment context aggregation",
  "repository": {
    "url": "https://github.com/leilashellroot/confluence-data-center-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@leilashellroot/confluence-data-center-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CONFLUENCE_BASE_URL",
          "description": "Confluence base URL, without /rest/api",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "CONFLUENCE_API_TOKEN",
          "description": "Confluence personal access token or API token",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
